# ═══════════════════════════════════════════════════════
# CHR-System — Supabase + Gemini Stack
# ═══════════════════════════════════════════════════════

# Supabase (supabase.com → project settings → API)
DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# NextAuth v5 (still needed for session management)
AUTH_SECRET=""             # openssl rand -base64 32
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"     # Required for Next.js 15 localhost proxy bugs
ACCESS_TOKEN_SECRET=""     # openssl rand -base64 32

# Record Encryption — EXACTLY 32 bytes
RECORD_ENCRYPTION_KEY=""   # openssl rand -base64 32

# Gemini AI (aistudio.google.com → Get API Key)
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-1.5-flash"

# Upstash Redis (upstash.com → free tier)
UPSTASH_REDIS_REST_URL="https://[id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# Resend Email (resend.com → free tier)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# Sentry (sentry.io → free tier — optional)
SENTRY_DSN=""

# Node
NODE_ENV="development"
