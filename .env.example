# ═══════════════════════════════════════════════════════
# CHR-System Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# ═══════════════════════════════════════════════════════

# PostgreSQL
DATABASE_URL="postgresql://chr_user:chr_password@localhost:5432/chr_system"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth v5
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Access Token Signing (JWT)
ACCESS_TOKEN_SECRET=""

# Record Encryption — EXACTLY 32 bytes, base64 encoded
# Generate: openssl rand -base64 32
RECORD_ENCRYPTION_KEY=""

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ROOT_USER="admin"
MINIO_ROOT_PASSWORD=""

# Meilisearch (full-text search)
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# Ollama (local AI inference)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"

# SMTP (email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# Sentry (optional — error tracking)
SENTRY_DSN=""

# Node
NODE_ENV="development"
