generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  PATIENT
  RECEPTIONIST
  LAB_TECH
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAIL
  VIEW
  CREATE
  UPDATE
  DELETE
  EXPORT
  ROLE_CHANGE
  AI_CALL
}

model Clinic {
  id        String    @id @default(uuid()) @db.Uuid // Using standard UUID for simplicity, would ideally be UUID v7 generated in TS
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz

  users          User[]
  auditLogs      AuditLog[]
  patients       Patient[]
  vitals         Vitals[]
  medicalRecords MedicalRecord[]
  appointments   Appointment[]
  prescriptions  Prescription[]
  labResults     LabResult[]
  notifications  Notification[]

  @@map("clinics")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  role         Role
  clinicId     String?   @db.Uuid
  isActive     Boolean   @default(true)
  mfaSecret    Bytes?    // Encrypted AES-256-GCM
  mfaEnabled   Boolean   @default(false)
  lastLoginAt  DateTime? @db.Timestamptz
  failedLogins Int       @default(0)
  lockedUntil  DateTime? @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  version      Int       @default(1)

  clinic       Clinic?   @relation(fields: [clinicId], references: [id])
  auditLogs    AuditLog[]

  // Reverse relations for Phase 2
  patientProfile Patient?  @relation(name: "PatientUserLink")
  patientsAsDoctor Patient[] @relation(name: "AssignedDoctor")
  patientsAsNurse Patient[] @relation(name: "AssignedNurse")
  recordedVitals Vitals[]
  doctorAppointments Appointment[] @relation(name: "DoctorAppointments")
  doctorPrescriptions Prescription[] @relation(name: "DoctorPrescriptions")
  orderedLabs    LabResult[] @relation(name: "OrderedLabs")
  resultedLabs   LabResult[] @relation(name: "ResultedLabs")
  notifications  Notification[]
  authoredRecords MedicalRecord[]

  @@index([clinicId, deletedAt])
  @@index([email])
  @@map("users")
}

model AuditLog {
  id         BigInt      @id @default(autoincrement())
  userId     String?     @db.Uuid // Optional to handle pre-auth logs (like LOGIN_FAIL)
  action     AuditAction
  resource   String
  resourceId String?     @db.Uuid
  clinicId   String?     @db.Uuid // Important for cross-tenant isolation auditing
  ipAddress  String?
  userAgent  String?
  requestId  String?     @db.Uuid
  metadata   Json?
  timestamp  DateTime    @default(now()) @db.Timestamptz

  user       User?       @relation(fields: [userId], references: [id])
  clinic     Clinic?     @relation(fields: [clinicId], references: [id])

  // NOTE: In a real production DB, this would be a BRIN index.
  // Prisma doesn't natively support BRIN index creation yet, so we use a regular btree index for now.
  @@index([timestamp])
  @@map("audit_logs")
}

model Patient {
  id               String    @id @default(uuid()) @db.Uuid
  mrn              String    @unique
  firstName        String
  lastName         String
  dob              DateTime  @db.Date
  gender           String
  bloodType        String?
  allergies        String[]
  phone            String?
  email            String?
  address          String?
  emergencyContact String?
  
  // Relationships
  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])
  
  userId           String?   @unique @db.Uuid // If they have portal access
  user             User?     @relation(name: "PatientUserLink", fields: [userId], references: [id])

  assignedDoctorId String?   @db.Uuid
  assignedDoctor   User?     @relation(name: "AssignedDoctor", fields: [assignedDoctorId], references: [id])

  assignedNurseId  String?   @db.Uuid
  assignedNurse    User?     @relation(name: "AssignedNurse", fields: [assignedNurseId], references: [id])

  vitals           Vitals[]
  medicalRecords   MedicalRecord[]
  appointments     Appointment[]
  prescriptions    Prescription[]
  labResults       LabResult[]

  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz
  version          Int       @default(1)

  @@index([clinicId, deletedAt])
  @@index([mrn])
  @@index([assignedDoctorId])
  @@index([assignedNurseId])
  @@map("patients")
}

model Vitals {
  id               String    @id @default(uuid()) @db.Uuid
  
  patientId        String    @db.Uuid
  patient          Patient   @relation(fields: [patientId], references: [id])

  recordedById     String    @db.Uuid
  recordedBy       User      @relation(fields: [recordedById], references: [id])

  recordedAt       DateTime  @default(now()) @db.Timestamptz
  
  bpSystolic       Int?
  bpDiastolic      Int?
  heartRate        Int?
  spo2             Int?
  temperatureF     Float?
  respiratoryRate  Int?
  weightKg         Float?
  heightCm         Float?
  notes            String?

  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])

  @@index([patientId, recordedAt(sort: Desc)])
  @@index([clinicId])
  @@map("vitals")
}

model MedicalRecord {
  id               String    @id @default(uuid()) @db.Uuid
  
  patientId        String    @db.Uuid
  patient          Patient   @relation(fields: [patientId], references: [id])

  doctorId         String    @db.Uuid
  doctor           User      @relation(fields: [doctorId], references: [id])

  recordType       String    // e.g. "SOAP_NOTE", "CONSULTATION"
  
  // Encrypted fields (AES-256-GCM)
  encryptedContent Bytes
  iv               Bytes
  authTag          Bytes

  diagnosisCodes   String[]  // e.g. ["I21.9", "E11.9"]
  attachments      String[]  // S3 object keys

  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])

  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz

  @@index([patientId, createdAt(sort: Desc)])
  @@index([clinicId, deletedAt])
  @@map("medical_records")
}

// ── FS-004 Appointment Scheduling ──────────────────────────────────

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  CONSULTATION
  FOLLOW_UP
  EMERGENCY
  LAB_REVIEW
  PROCEDURE
}

model Appointment {
  id               String            @id @default(uuid()) @db.Uuid

  patientId        String            @db.Uuid
  patient          Patient           @relation(fields: [patientId], references: [id])

  doctorId         String            @db.Uuid
  doctor           User              @relation(name: "DoctorAppointments", fields: [doctorId], references: [id])

  scheduledStart   DateTime          @db.Timestamptz
  scheduledEnd     DateTime          @db.Timestamptz

  status           AppointmentStatus @default(PENDING)
  type             AppointmentType   @default(CONSULTATION)
  reason           String?
  notes            String?
  cancelReason     String?

  clinicId         String            @db.Uuid
  clinic           Clinic            @relation(fields: [clinicId], references: [id])

  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz

  @@index([doctorId, scheduledStart])
  @@index([patientId, scheduledStart])
  @@index([clinicId, status])
  @@map("appointments")
}

// ── FS-007 Prescription Management ─────────────────────────────────

model Prescription {
  id               String    @id @default(uuid()) @db.Uuid

  patientId        String    @db.Uuid
  patient          Patient   @relation(fields: [patientId], references: [id])

  doctorId         String    @db.Uuid
  doctor           User      @relation(name: "DoctorPrescriptions", fields: [doctorId], references: [id])

  medicationName   String
  dosage           String
  unit             String
  frequency        String
  route            String?
  startDate        DateTime  @db.Date
  endDate          DateTime? @db.Date
  isActive         Boolean   @default(true)
  notes            String?
  icd10Code        String?

  discontinuedAt   DateTime? @db.Timestamptz
  discontinuedById String?   @db.Uuid

  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])

  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  @@index([patientId, isActive])
  @@index([clinicId])
  @@map("prescriptions")
}

// ── FS-008 Lab Results Management ──────────────────────────────────

enum LabStatus {
  PENDING
  RESULTED
  REVIEWED
}

model LabResult {
  id                 String    @id @default(uuid()) @db.Uuid

  patientId          String    @db.Uuid
  patient            Patient   @relation(fields: [patientId], references: [id])

  testName           String
  resultValue        String?   // Numeric or text result
  unit               String?
  referenceRangeLow  Float?
  referenceRangeHigh Float?
  isAbnormal         Boolean   @default(false)
  status             LabStatus @default(PENDING)

  orderedById        String    @db.Uuid
  orderedBy          User      @relation(name: "OrderedLabs", fields: [orderedById], references: [id])

  resultedById       String?   @db.Uuid
  resultedBy         User?     @relation(name: "ResultedLabs", fields: [resultedById], references: [id])

  orderedAt          DateTime  @default(now()) @db.Timestamptz
  resultedAt         DateTime? @db.Timestamptz
  reviewedAt         DateTime? @db.Timestamptz

  clinicId           String    @db.Uuid
  clinic             Clinic    @relation(fields: [clinicId], references: [id])

  createdAt          DateTime  @default(now()) @db.Timestamptz
  updatedAt          DateTime  @updatedAt @db.Timestamptz

  @@index([patientId, orderedAt(sort: Desc)])
  @@index([clinicId, status])
  @@map("lab_results")
}

// ── FS-012 Notifications ───────────────────────────────────────────

enum NotificationType {
  VITAL_ALERT
  LAB_ABNORMAL
  APPOINTMENT_REMINDER
  ROLE_CHANGE
  SYSTEM
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid

  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id])

  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  link      String?

  clinicId  String?          @db.Uuid
  clinic    Clinic?          @relation(fields: [clinicId], references: [id])

  createdAt DateTime         @default(now()) @db.Timestamptz

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([clinicId])
  @@map("notifications")
}

