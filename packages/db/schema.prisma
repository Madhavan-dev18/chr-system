generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  PATIENT
  RECEPTIONIST
  LAB_TECH
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAIL
  VIEW
  CREATE
  UPDATE
  DELETE
  EXPORT
  ROLE_CHANGE
  AI_CALL
}

model Clinic {
  id        String    @id @default(uuid()) @db.Uuid // Using standard UUID for simplicity, would ideally be UUID v7 generated in TS
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz

  users          User[]
  auditLogs      AuditLog[]
  patients       Patient[]
  vitals         Vitals[]
  medicalRecords MedicalRecord[]

  @@map("clinics")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  role         Role
  clinicId     String?   @db.Uuid
  isActive     Boolean   @default(true)
  mfaSecret    Bytes?    // Encrypted AES-256-GCM
  mfaEnabled   Boolean   @default(false)
  lastLoginAt  DateTime? @db.Timestamptz
  failedLogins Int       @default(0)
  lockedUntil  DateTime? @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  version      Int       @default(1)

  clinic       Clinic?   @relation(fields: [clinicId], references: [id])
  auditLogs    AuditLog[]

  // Reverse relations for Phase 2
  patientProfile Patient?  @relation(name: "PatientUserLink")
  patientsAsDoctor Patient[] @relation(name: "AssignedDoctor")
  patientsAsNurse Patient[] @relation(name: "AssignedNurse")
  recordedVitals Vitals[]
  authoredRecords MedicalRecord[]

  @@index([clinicId, deletedAt])
  @@index([email])
  @@map("users")
}

model AuditLog {
  id         BigInt      @id @default(autoincrement())
  userId     String?     @db.Uuid // Optional to handle pre-auth logs (like LOGIN_FAIL)
  action     AuditAction
  resource   String
  resourceId String?     @db.Uuid
  clinicId   String?     @db.Uuid // Important for cross-tenant isolation auditing
  ipAddress  String?
  userAgent  String?
  requestId  String?     @db.Uuid
  metadata   Json?
  timestamp  DateTime    @default(now()) @db.Timestamptz

  user       User?       @relation(fields: [userId], references: [id])
  clinic     Clinic?     @relation(fields: [clinicId], references: [id])

  // NOTE: In a real production DB, this would be a BRIN index.
  // Prisma doesn't natively support BRIN index creation yet, so we use a regular btree index for now.
  @@index([timestamp])
  @@map("audit_logs")
}

model Patient {
  id               String    @id @default(uuid()) @db.Uuid
  mrn              String    @unique
  firstName        String
  lastName         String
  dob              DateTime  @db.Date
  gender           String
  bloodType        String?
  allergies        String[]
  phone            String?
  email            String?
  address          String?
  emergencyContact String?
  
  // Relationships
  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])
  
  userId           String?   @unique @db.Uuid // If they have portal access
  user             User?     @relation(name: "PatientUserLink", fields: [userId], references: [id])

  assignedDoctorId String?   @db.Uuid
  assignedDoctor   User?     @relation(name: "AssignedDoctor", fields: [assignedDoctorId], references: [id])

  assignedNurseId  String?   @db.Uuid
  assignedNurse    User?     @relation(name: "AssignedNurse", fields: [assignedNurseId], references: [id])

  vitals           Vitals[]
  medicalRecords   MedicalRecord[]

  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz
  version          Int       @default(1)

  @@index([clinicId, deletedAt])
  @@index([mrn])
  @@index([assignedDoctorId])
  @@index([assignedNurseId])
  @@map("patients")
}

model Vitals {
  id               String    @id @default(uuid()) @db.Uuid
  
  patientId        String    @db.Uuid
  patient          Patient   @relation(fields: [patientId], references: [id])

  recordedById     String    @db.Uuid
  recordedBy       User      @relation(fields: [recordedById], references: [id])

  recordedAt       DateTime  @default(now()) @db.Timestamptz
  
  bpSystolic       Int?
  bpDiastolic      Int?
  heartRate        Int?
  spo2             Int?
  temperatureF     Float?
  respiratoryRate  Int?
  weightKg         Float?
  heightCm         Float?
  notes            String?

  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])

  @@index([patientId, recordedAt(sort: Desc)])
  @@index([clinicId])
  @@map("vitals")
}

model MedicalRecord {
  id               String    @id @default(uuid()) @db.Uuid
  
  patientId        String    @db.Uuid
  patient          Patient   @relation(fields: [patientId], references: [id])

  doctorId         String    @db.Uuid
  doctor           User      @relation(fields: [doctorId], references: [id])

  recordType       String    // e.g. "SOAP_NOTE", "CONSULTATION"
  
  // Encrypted fields (AES-256-GCM)
  encryptedContent Bytes
  iv               Bytes
  authTag          Bytes

  diagnosisCodes   String[]  // e.g. ["I21.9", "E11.9"]
  attachments      String[]  // S3 object keys

  clinicId         String    @db.Uuid
  clinic           Clinic    @relation(fields: [clinicId], references: [id])

  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  deletedAt        DateTime? @db.Timestamptz

  @@index([patientId, createdAt(sort: Desc)])
  @@index([clinicId, deletedAt])
  @@map("medical_records")
}
