{
  "name": "@chr/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "node -e \"const env = { ...process.env, HOME: process.env.TEMP || '/tmp', USERPROFILE: process.env.TEMP || '/tmp', APPDATA: process.env.TEMP || '/tmp', LOCALAPPDATA: process.env.TEMP || '/tmp' }; require('child_process').execSync('next build', { env, stdio: 'inherit' })\"",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chr/db": "*",
    "@hookform/resolvers": "^4.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "jose": "^6.0.0",
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "next-auth": "5.0.0-beta.31",
    "otplib": "^13.4.1",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.0.0",
    "recharts": "^3.9.0",
    "superjson": "^2.2.0",
    "tailwind-merge": "^3.6.0",
    "uuidv7": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.0.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
