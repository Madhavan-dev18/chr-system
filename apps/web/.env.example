# ============================================================
# CHR System — Environment Variables
# Copy to .env.local and fill in your values.
# DO NOT commit .env.local to source control.
# ============================================================

# ── Database (Supabase) ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Cache (Upstash Redis) ────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://[id].upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxx..."

# ── Auth (NextAuth v5) ───────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_AT_LEAST_32_CHARS"
AUTH_URL="http://localhost:3000"
# Set to "true" in production on Vercel/Railway
AUTH_TRUST_HOST="true"

# ── Security Secrets ─────────────────────────────────────────────
# Generate: openssl rand -base64 32
ACCESS_TOKEN_SECRET="CHANGE_ME_AT_LEAST_32_CHARS"

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must decode to exactly 32 bytes (44 base64 chars)
RECORD_ENCRYPTION_KEY="CHANGE_ME_44_CHAR_BASE64_STRING_HERE"

# ── AI (Google Gemini) ───────────────────────────────────────────
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-1.5-flash"

# ── Email (Resend) — Optional ────────────────────────────────────
# RESEND_API_KEY="re_..."
# EMAIL_FROM="noreply@your-clinic.com"

# ── Observability — Optional ─────────────────────────────────────
# SENTRY_DSN="https://...@sentry.io/..."

# ── Build ────────────────────────────────────────────────────────
NODE_ENV="development"
# Set to "standalone" for Docker/Railway/Fly deployments
# NEXT_OUTPUT="standalone"
